{
  "name": "strav",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\""
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "reflect-metadata": "^0.2.2"
  }
}